@page "/dashboard"
@rendermode InteractiveServer
@using BlazorApp.Models
@using BlazorApp.Services
@using System.Text.Json
@implements IDisposable
@inject IKafkaService KafkaService
@inject IConfiguration Configuration

<PageTitle>Data Dashboard</PageTitle>

<div class="dashboard-container">
    <header class="dashboard-header">
        <h1>Trip Analytics Dashboard</h1>
        <p>Real-time insights from Kafka streams (Optimized)</p>
    </header>

    <div class="stats-grid">
        <!-- Average Duration Card -->
        <div class="stat-card glass secondary">
            <div class="card-icon">⏱️</div>
            <div class="card-content">
                <h3>Avg. Duration</h3>
                <div class="card-value">@(_latestAvg?.AverageDuration.ToString("N1") ?? "---") <span class="unit">sec</span></div>
            </div>
        </div>

        <!-- Trip Count Card -->
        <div class="stat-card glass primary">
            <div class="card-icon">🚲</div>
            <div class="card-content">
                <h3>Total Trips Today</h3>
                <div class="card-value">@(_latestCount?.Count.ToString("N0") ?? "---")</div>
            </div>
        </div>

        <!-- Popular Station Card -->
        <div class="stat-card glass accent">
            <div class="card-icon">📍</div>
            <div class="card-content">
                <h3>Hot Start Station</h3>
                <div class="card-value station">@(_latestPopular?.StationName ?? "---")</div>
                <div class="card-subtitle">@(_latestPopular?.Count ?? 0) starts today</div>
            </div>
        </div>
    </div>

    <div class="ranking-section glass">
        <div class="section-header">
            <h3>🏆 Top 3 Transit Hubs</h3>
            <span class="badge">Start + End combined</span>
        </div>
        <div class="ranking-list">
            @if (_latestTop3?.TopStations != null && _latestTop3.TopStations.Any())
            {
                int rank = 1;
                foreach (var station in _latestTop3.TopStations)
                {
                    <div class="ranking-item">
                        <div class="rank">#@rank</div>
                        <div class="station-info">
                            <span class="station-name">@station.StationName</span>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: @(GetRankWidth(station.TotalVisits))%"></div>
                            </div>
                        </div>
                        <div class="visits">@station.TotalVisits <small>visits</small></div>
                    </div>
                    rank++;
                }
            }
            else
            {
                <div class="no-data">Waiting for data stream...</div>
            }
        </div>
    </div>
</div>

@code {
    private DailyAverageDuration? _latestAvg;
    private DailyTripCount? _latestCount;
    private DailyPopularStartStation? _latestPopular;
    private DailyTopStations? _latestTop3;

    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        var topicAvg = Configuration["Kafka:TopicAvgDuration"] ?? "AvgDurationByDay";
        var topicCount = Configuration["Kafka:TopicTripCount"] ?? "TripCountByDay";
        var topicPopular = Configuration["Kafka:TopicPopularStart"] ?? "PopularStartStationByDay";
        var topicTop3 = Configuration["Kafka:TopicTop3Stations"] ?? "Top3StationsByDay";

        var topics = new[] { topicAvg, topicCount, topicPopular, topicTop3 };

        KafkaService.Subscribe(topics, (topic, value) => 
        {
            InvokeAsync(() => 
            {
                try {
                    var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

                    if (topic == topicAvg)
                        _latestAvg = JsonSerializer.Deserialize<DailyAverageDuration>(value, options);
                    else if (topic == topicCount)
                        _latestCount = JsonSerializer.Deserialize<DailyTripCount>(value, options);
                    else if (topic == topicPopular)
                        _latestPopular = JsonSerializer.Deserialize<DailyPopularStartStation>(value, options);
                    else if (topic == topicTop3)
                        _latestTop3 = JsonSerializer.Deserialize<DailyTopStations>(value, options);

                    StateHasChanged();
                }
                catch (Exception ex) {
                    Console.WriteLine($"Error processing message from topic {topic}: {ex.Message}");
                }
            });
        }, _cts.Token);
    }

    private double GetRankWidth(int visits)
    {
        if (_latestTop3?.TopStations == null || !_latestTop3.TopStations.Any()) return 0;
        var max = _latestTop3.TopStations.First().TotalVisits;
        return (double)visits / max * 100;
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
